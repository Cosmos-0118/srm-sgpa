{
  "manifest_version": 3,
  "name": "SRM SGPA Calculator",
  "short_name": "srmcgpa",
  "version": "1.1",
  "description": "Automatically calculates and displays SGPA and CGPA on the SRM student portal.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "srmcgpa — SGPA / CGPA Calculator"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://sp.srmist.edu.in/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
